{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "dgfoam-build-debug-libs",
            "command": "bash",
            "args": [
                "-lc",
                "source ${workspaceFolder}/etc/use-debug.sh && cd ${workspaceFolder}/src && ./Allwmake"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "type": "shell",
            "label": "dgfoam-build-debug-solver",
            "command": "bash",
            "args": [
                "-lc",
                "source ${workspaceFolder}/etc/use-debug.sh && cd ${workspaceFolder}/applications/solvers/compressible/DGHyperSonicFoam && wmake"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "dgfoam-build-debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "dgfoam-build-debug-libs",
                "dgfoam-build-debug-solver"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "shell",
            "label": "dgfoam-decompose-case-debug",
            "command": "bash",
            "args": [
                "-lc",
                "source ${workspaceFolder}/etc/use-debug.sh && cd ${input:dgCaseDir} && decomposePar -force"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "type": "shell",
            "label": "dgfoam-run-mpi-debug",
            "command": "bash",
            "args": [
                "-lc",
                "source ${workspaceFolder}/etc/use-debug.sh && cd ${input:dgCaseDir} && mpirun -np ${input:dgMpiRanks} ${workspaceFolder}/platforms/linux64GccDPInt32Debug/bin/DGHyperSonicFoam -parallel"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        }
    ],
    "inputs": [
        {
            "id": "dgCaseDir",
            "type": "promptString",
            "description": "Absolute path to the OpenFOAM case directory",
            "default": "/home/nam-ha-tran/OpenFOAM/DGFoam/applications/test/testCase"
        },
        {
            "id": "dgMpiRanks",
            "type": "promptString",
            "description": "Number of MPI ranks",
            "default": "2"
        }
    ]
}
