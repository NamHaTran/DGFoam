FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      dgOptions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
limiters
{
	ppLimiter
	{
		type			positivityPreserving;
		density			rho;
		momentum		rhoU;
		energy			E;
		// fields		(rho rhoU E);
		
		// trouble cell detector
		detector 		PerssonPeraire;
		PerssonPeraireCoeffs
		{
			checkFields  (rho);
			kappa        1.0;
			report       false;
		}
	}
}
